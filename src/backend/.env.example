# ── Required ──────────────────────────────────────────────────────────
# Google Gemini API key — used for LLM chat responses and context compaction
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────────────────
# Sarvam AI — used for translation and text-to-speech features
# Leave blank to disable translation/TTS endpoints
SARVAM_API_KEY=your_sarvam_api_key_here
